# AffectLog – Trustworthy AI Assessment
# Prometheus-X BB04 / EDGE-Skills
# Copy to .env and fill in secrets. NEVER commit .env — it is excluded by .gitignore.

# ── Application ─────────────────────────────────────────────────────────
AFFECTLOG_APP_ENV=development
AFFECTLOG_APP_BASE_URL=http://localhost:3000
AFFECTLOG_API_HOST=0.0.0.0
AFFECTLOG_API_PORT=8000
AFFECTLOG_API_WORKERS=4

# ── Database ─────────────────────────────────────────────────────────────
# PostgreSQL credentials consumed by docker-compose (postgres service + app URLs).
# REQUIRED: POSTGRES_PASSWORD has no default — compose refuses to start if unset.
# Generate a strong value: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_USER=affectlog
POSTGRES_PASSWORD=
POSTGRES_DB=affectlog
# Direct connection string (used when running the app outside Docker). Keep the
# credentials here in sync with POSTGRES_USER / POSTGRES_PASSWORD above.
AFFECTLOG_DATABASE_URL=postgresql+psycopg://affectlog:CHANGE_ME@localhost:5432/affectlog
# For local dev without Docker: AFFECTLOG_DATABASE_URL=sqlite+aiosqlite:///./affectlog_dev.db
AFFECTLOG_DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────
AFFECTLOG_REDIS_URL=redis://localhost:6379/0
AFFECTLOG_CELERY_BROKER_URL=redis://localhost:6379/0
AFFECTLOG_CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Auth secrets — REQUIRED in production ────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AFFECTLOG_SECRET_KEY=
AFFECTLOG_PASSWORD_PEPPER=
AFFECTLOG_HASH_SECRET=
AFFECTLOG_CSRF_SECRET=

# ── Session / Cookie ─────────────────────────────────────────────────────
AFFECTLOG_COOKIE_SECURE=false
AFFECTLOG_COOKIE_SAMESITE=lax
AFFECTLOG_SESSION_TTL_SECONDS=604800

# ── SMTP / Email ─────────────────────────────────────────────────────────
# Gmail: enable 2FA, create App Password at myaccount.google.com → Security → App passwords
AFFECTLOG_SMTP_HOST=smtp.gmail.com
AFFECTLOG_SMTP_PORT=587
AFFECTLOG_SMTP_USERNAME=
AFFECTLOG_SMTP_PASSWORD=
AFFECTLOG_SMTP_FROM_EMAIL=
AFFECTLOG_SMTP_FROM_NAME=AffectLog Trustworthy AI
AFFECTLOG_SMTP_USE_TLS=true
AFFECTLOG_EMAIL_SEND_ENABLED=false
AFFECTLOG_DEV_SHOW_ACTIVATION_LINK=true

# ── Registration / Approval ───────────────────────────────────────────────
AFFECTLOG_PUBLIC_REGISTRATION_ENABLED=true
AFFECTLOG_ADMIN_APPROVAL_REQUIRED=true

# ── Privacy defaults ──────────────────────────────────────────────────────
AFFECTLOG_ALLOW_RAW_IDENTIFIERS=false
AFFECTLOG_PSEUDONYMIZE=true
AFFECTLOG_RAW_EXPORTS_ENABLED=false

# ── CORS ─────────────────────────────────────────────────────────────────
AFFECTLOG_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Logging ───────────────────────────────────────────────────────────────
AFFECTLOG_LOG_LEVEL=INFO
AFFECTLOG_LOG_FORMAT=text

# ── PDC (optional) ────────────────────────────────────────────────────────
AFFECTLOG_PDC_URL=
AFFECTLOG_PDC_TOKEN=

# ── Frontend ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Storage ───────────────────────────────────────────────────────────────
AFFECTLOG_DATA_DIR=data
AFFECTLOG_RUNS_DIR=runs
AFFECTLOG_MAX_UPLOAD_BYTES=2147483648
