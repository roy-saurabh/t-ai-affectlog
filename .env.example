# AffectLog ALT-AI — Environment Variables
# Copy to .env and fill in values. NEVER commit .env

# Pseudonymisation secret (REQUIRED for production — use a long random string)
AFFECTLOG_HASH_SECRET=change-me-to-a-long-random-string-in-production

# API server
AFFECTLOG_API_HOST=0.0.0.0
AFFECTLOG_API_PORT=8000
AFFECTLOG_API_WORKERS=4

# Logging
AFFECTLOG_LOG_LEVEL=INFO
AFFECTLOG_LOG_FORMAT=json

# Storage
AFFECTLOG_DATA_DIR=data
AFFECTLOG_RUNS_DIR=runs
AFFECTLOG_CHUNK_SIZE=100000

# Privacy defaults (do not change unless you have legal clearance)
AFFECTLOG_ALLOW_RAW_IDENTIFIERS=false
AFFECTLOG_PSEUDONYMIZE=true

# PDC / Prometheus-X (optional — leave empty for local-only operation)
AFFECTLOG_PDC_URL=
AFFECTLOG_PDC_TOKEN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
